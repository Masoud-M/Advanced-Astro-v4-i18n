---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "src/features/demo/Hero.astro";
import Services from "src/features/demo/Services.astro";
import SideBySide from "src/features/demo/SideBySide.astro";
import SideBySideReverse from "src/features/demo/SideBySideReverse.astro";
import Gallery from "src/features/demo/Gallery.astro";
import Testimonials from "src/features/demo/Testimonials.astro";
import landingImage from "@assets/images/hero.jpg";
import { getSiteContext } from "@js/getSiteContext";
import BrowserLanguageRedirect from "src/features/i18n/LanguageSwitch/BrowserLanguageRedirect.astro";
import CTA from "src/features/demo/CTA.astro";

const { content } = await getSiteContext(Astro.url);
---

<BrowserLanguageRedirect />

<BaseLayout
  title={content.home.layout.title}
  description={content.home.layout.description}
>
  <Hero image={landingImage} />
  <Services />
  <SideBySide />
  <SideBySideReverse />
  <Gallery />
  <Testimonials />
  <CTA />
</BaseLayout>
