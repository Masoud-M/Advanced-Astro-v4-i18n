---
import type { GetStaticPaths } from "astro";
import { getSiteContext } from "@js/getSiteContext";
import { getPostSlug } from "src/features/decapCMS/core/blogUtils";
import { getBlogPostingSchema } from "src/features/decapCMS/core/blogPostingSchema";
import { getBlogPosts } from "src/features/decapCMS/core/getBlogPosts";
import BaseLayout from "@layouts/BaseLayout.astro";
import Banner from "src/features/demo/Banner.astro";
import BlogFullArticle from "src/features/decapCMS/BlogFullArticle.astro";
import FeaturedPost from "src/features/decapCMS/FeaturedPost.astro";

import landingImage from "@assets/images/landing.jpg";

export const getStaticPaths = (async () => {
  const locale = "en";
  const posts = await getBlogPosts(locale);

  return posts.map((post) => ({
    params: {
      slug: getPostSlug(post),
    },
    props: { post },
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { content, locale } = await getSiteContext(Astro.url);

const postUrl = new URL(Astro.url.pathname, Astro.site).href;
const blogSchema = getBlogPostingSchema(post, locale, postUrl);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <script
    type="application/ld+json"
    slot="schema"
    set:html={JSON.stringify(blogSchema)}
  />

  <Banner title={content.blog.landing} image={landingImage} />

  <section class="main-content-wrapper">
    <!--Main content -->
    <div class="main-content">
      <BlogFullArticle post={post} />
    </div>
    <FeaturedPost />
  </section>
</BaseLayout>

<style lang="less">
  /* Mobile - 360px */
  @media only screen and (min-width: 0em) {
    .main-content-wrapper {
      padding: var(--sectionPadding);
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: (50/16em);
    }

    .main-content {
      // width: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      row-gap: (50/16em);
    }
  }

  /* Tablet - 1024px */
  @media only screen and (min-width: 64em) {
    .main-content-wrapper {
      flex-direction: row;
      align-items: flex-start;
    }
  }
</style>
